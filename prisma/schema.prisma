generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model FileItem {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("file") // "file" or "folder"
  size        Int      @default(0) // in bytes
  mimeType    String   @default("")
  parentId    String?  // null means top level (root)
  storagePath String?  @default("") // local file system path (only for files)
  isStarred   Boolean  @default(false)
  isTrashed   Boolean  @default(false)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation to children
  children    FileItem[]   @relation("FileHierarchy")
  parent      FileItem?    @relation("FileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  shares      ShareLink[]
  versions    FileVersion[]

  @@index([parentId])
  @@index([isTrashed])
  @@index([isStarred])
  @@index([name])
}

model ShareLink {
  id        String   @id @default(cuid())
  fileId    String
  token     String   @unique
  password  String?  @default("")
  expiresAt DateTime?
  downloadCount Int  @default(0)
  createdAt DateTime @default(now())

  file      FileItem  @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([fileId])
}

model FileVersion {
  id          String   @id @default(cuid())
  fileId      String
  name        String
  size        Int      @default(0)
  mimeType    String   @default("")
  storagePath String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  file        FileItem  @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([fileId, version])
}
