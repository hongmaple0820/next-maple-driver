generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          String    @default("user") // "admin" or "user"
  avatarUrl     String?
  storageLimit  BigInt    @default(10737418240) // 10GB in bytes
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  files                FileItem[]
  shares               ShareLink[]
  transfers            TransferFile[]
  quickTransferSessions QuickTransferSession[]
  taskRecords          TaskRecord[]

  @@index([email])
}

model FileItem {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("file") // "file" or "folder"
  size        Int      @default(0) // in bytes
  mimeType    String   @default("")
  parentId    String?  // null means top level (root)
  storagePath String?  @default("") // local file system path (only for files)
  driverId    String?  // which storage driver this file is stored on (null = default local)
  isStarred   Boolean  @default(false)
  isTrashed   Boolean  @default(false)
  description String?
  colorLabel  String   @default("") // "red", "orange", "yellow", "green", "blue", "purple", "pink", "gray", or "" (none)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation to children
  children    FileItem[]   @relation("FileHierarchy")
  parent      FileItem?    @relation("FileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares      ShareLink[]
  versions    FileVersion[]

  @@index([parentId])
  @@index([isTrashed])
  @@index([isStarred])
  @@index([name])
  @@index([userId])
}

model ShareLink {
  id            String   @id @default(cuid())
  fileId        String
  token         String   @unique
  password      String?  @default("")
  expiresAt     DateTime?
  downloadCount Int      @default(0)
  userId        String?
  createdAt     DateTime @default(now())

  file      FileItem  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([fileId])
  @@index([userId])
}

model FileVersion {
  id          String   @id @default(cuid())
  fileId      String
  name        String
  size        Int      @default(0)
  mimeType    String   @default("")
  storagePath String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  file        FileItem  @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([fileId, version])
}

model StorageDriver {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("local") // "local", "webdav", "s3", "mount", "ftp", "baidu", "aliyun", "onedrive", "google", "115", "quark"
  basePath        String?   @default("") // File system path for local/mount drivers
  config          String    @default("{}") // JSON string of driver-specific config
  status          String    @default("active") // "active", "inactive", "error"
  isDefault       Boolean   @default(false)
  isEnabled       Boolean   @default(true)
  priority        Int       @default(0) // Higher priority drivers are tried first
  mountPath       String?   @default("") // Virtual mount path in VFS (e.g., "/baidu", "/s3-backup")
  isReadOnly      Boolean   @default(false) // Whether this mount is read-only
  // Cloud driver auth fields
  authType        String    @default("none") // "oauth", "password", "sms", "email", "none"
  authStatus      String    @default("pending") // "pending", "authorized", "expired", "error"
  accessToken     String?   // OAuth access token
  refreshToken    String?   // OAuth refresh token
  tokenExpiresAt  DateTime? // When the access token expires
  lastSyncAt      DateTime? // Last successful sync timestamp
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([type])
  @@index([isDefault])
  @@index([status])
  @@index([authType])
  @@index([authStatus])

  @@map("StorageDriverConfig")
}

model TransferFile {
  id            String    @id @default(cuid())
  token         String    @unique
  fileName      String
  fileSize      Int
  mimeType      String    @default("")
  storagePath   String
  password      String?   @default("")
  expiresAt     DateTime?
  downloadCount Int       @default(0)
  maxDownloads  Int       @default(-1) // -1 means unlimited
  userId        String?   // null for anonymous
  isAnonymous   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model QuickTransferSession {
  id          String   @id @default(cuid())
  code        String   @unique  // 6-character code
  userId      String
  folderId    String?  // target folder (null = root)
  folderName  String   @default("/") // display name of target folder
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  history     QuickTransferHistory[]

  @@index([code])
  @@index([userId])
  @@index([isActive])
}

model QuickTransferHistory {
  id          String   @id @default(cuid())
  sessionId   String
  senderName  String   @default("Anonymous")
  fileName    String
  fileSize    Int      @default(0)
  fileCount   Int      @default(1)
  status      String   @default("completed") // "completed", "failed"
  createdAt   DateTime @default(now())

  session     QuickTransferSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([createdAt])
}

model TaskRecord {
  id          String   @id @default(cuid())
  userId      String?
  type        String   // "upload", "download", "move", "copy", "quick-transfer", "transit"
  status      String   @default("pending") // "pending", "running", "paused", "completed", "failed", "cancelled"
  progress    Int      @default(0) // 0-100
  fileName    String
  fileSize    Int      @default(0)
  totalSize   Int      @default(0)
  chunkIndex  Int      @default(0) // for chunked uploads
  totalChunks Int      @default(0) // for chunked uploads
  uploadId    String?  // for chunked uploads
  sourcePath  String?  // for move/copy
  destPath    String?  // for move/copy
  sourceDriverId String?
  destDriverId   String?
  speed       Int      @default(0) // bytes per second
  error       String?
  metadata    String   @default("{}") // JSON for extra data
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
}

model TransferHistory {
  id            String    @id @default(cuid())
  token         String    // transfer token
  fileName      String
  fileSize      Int       @default(0)
  mimeType      String    @default("")
  userId        String?   // null for anonymous
  isAnonymous   Boolean   @default(false)
  action        String    @default("upload") // "upload", "download", "delete"
  recipientEmail String?  // email if sent via email
  status        String    @default("active") // "active", "expired", "deleted"
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([token])
  @@index([createdAt])
  @@index([status])
}

model VFSNode {
  id          String   @id @default(cuid())
  name        String   // Display name
  path        String   // Full virtual path (e.g., "/baidu/photos")
  parentId    String?  // Parent node ID (null for root-level mounts)
  driverId    String?  // Linked storage driver ID (null for virtual folders)
  driverPath  String?  @default("") // Path within the driver (if different from virtual path)
  isDir       Boolean  @default(true)
  isReadOnly  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      VFSNode?  @relation("VFSHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    VFSNode[] @relation("VFSHierarchy")

  @@unique([path])
  @@index([parentId])
  @@index([driverId])
}
