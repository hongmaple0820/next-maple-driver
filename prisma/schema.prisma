generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          String    @default("user") // "admin" or "user"
  avatarUrl     String?
  storageLimit  BigInt    @default(10737418240) // 10GB in bytes
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  files                FileItem[]
  shares               ShareLink[]
  transfers            TransferFile[]
  quickTransferSessions QuickTransferSession[]

  @@index([email])
}

model FileItem {
  id          String   @id @default(cuid())
  name        String
  type        String   @default("file") // "file" or "folder"
  size        Int      @default(0) // in bytes
  mimeType    String   @default("")
  parentId    String?  // null means top level (root)
  storagePath String?  @default("") // local file system path (only for files)
  driverId    String?  // which storage driver this file is stored on (null = default local)
  isStarred   Boolean  @default(false)
  isTrashed   Boolean  @default(false)
  description String?
  colorLabel  String   @default("") // "red", "orange", "yellow", "green", "blue", "purple", "pink", "gray", or "" (none)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relation to children
  children    FileItem[]   @relation("FileHierarchy")
  parent      FileItem?    @relation("FileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares      ShareLink[]
  versions    FileVersion[]

  @@index([parentId])
  @@index([isTrashed])
  @@index([isStarred])
  @@index([name])
  @@index([userId])
}

model ShareLink {
  id            String   @id @default(cuid())
  fileId        String
  token         String   @unique
  password      String?  @default("")
  expiresAt     DateTime?
  downloadCount Int      @default(0)
  userId        String?
  createdAt     DateTime @default(now())

  file      FileItem  @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([fileId])
  @@index([userId])
}

model FileVersion {
  id          String   @id @default(cuid())
  fileId      String
  name        String
  size        Int      @default(0)
  mimeType    String   @default("")
  storagePath String?
  version     Int      @default(1)
  createdAt   DateTime @default(now())

  file        FileItem  @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([fileId, version])
}

model StorageDriverConfig {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("local") // "local", "webdav", "s3", "mount", "baidu", "aliyun", "onedrive", "google", "115", "quark"
  basePath        String?   @default("") // File system path for local/mount drivers
  config          String    @default("{}") // JSON string of driver-specific config
  status          String    @default("active") // "active", "inactive", "error"
  isDefault       Boolean   @default(false)
  isEnabled       Boolean   @default(true)
  priority        Int       @default(0) // Higher priority drivers are tried first
  // Cloud driver auth fields
  authType        String    @default("none") // "oauth", "password", "sms", "email", "none"
  authStatus      String    @default("pending") // "pending", "authorized", "expired", "error"
  accessToken     String?   // OAuth access token
  refreshToken    String?   // OAuth refresh token
  tokenExpiresAt  DateTime? // When the access token expires
  lastSyncAt      DateTime? // Last successful sync timestamp
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([type])
  @@index([isDefault])
  @@index([status])
  @@index([authType])
  @@index([authStatus])
}

model TransferFile {
  id            String    @id @default(cuid())
  token         String    @unique
  fileName      String
  fileSize      Int
  mimeType      String    @default("")
  storagePath   String
  password      String?   @default("")
  expiresAt     DateTime?
  downloadCount Int       @default(0)
  maxDownloads  Int       @default(-1) // -1 means unlimited
  userId        String?   // null for anonymous
  isAnonymous   Boolean   @default(false)
  createdAt     DateTime  @default(now())

  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([expiresAt])
}

model QuickTransferSession {
  id          String   @id @default(cuid())
  code        String   @unique  // 6-character code
  userId      String
  folderId    String?  // target folder (null = root)
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([code])
  @@index([userId])
  @@index([isActive])
}
